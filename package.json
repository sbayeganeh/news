{
  "name": "news-ticker",
  "version": "1.0.0",
  "description": "Always-on-top news ticker with embedded LLM and DuckDuckGo search",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite build && electron .",
    "build": "vite build",
    "start": "electron .",
    "postinstall": "npx node-llama-cpp download"
