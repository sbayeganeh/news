    "electron",
    "llm"
  ],
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "duck-duck-scrape": "^2.2.7",
    "electron": "^41.0.4",
    "electron-store": "^11.0.2",
    "node-llama-cpp": "^3.18.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^6.4.1"
  }
}
