{
  "name": "news-ticker",
  "version": "1.0.0",
  "description": "Always-on-top news ticker with Google News RSS",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite build && electron .",
    "build": "vite build",
    "start": "electron .",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:win": "vite build && electron-builder --win",
    "dist:all": "vite build && electron-builder --mac --linux --win"
  },
  "keywords": [
    "news",
    "ticker",
    "electron"
  ],
  "license": "MIT",
  "author": {
    "name": "Saeid Bayeganeh",
    "email": "saeid@newsticker.app"
  },
  "homepage": "https://github.com/saeidbayeganeh/news-ticker",
  "dependencies": {
    "electron-store": "^11.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^6.4.1"
  },
  "build": {
    "appId": "com.newsticker.app",
    "productName": "News Ticker",
    "files": [
      "electron/**/*",
      "build/**/*",
      "assets/icon.png"
    ],
    "icon": "assets/icon.png",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.news",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "extendInfo": {
        "LSUIElement": false
      }
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network;News"
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
